-- Función para crear/quitar el texto flotante
local function createText()
	if textBillboard then
		textBillboard:Destroy()
	end
	
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "InvisibleText"
	billboard.Adornee = hrp
	billboard.Size = UDim2.new(0,300,0,50)
	billboard.StudsOffset = Vector3.new(0,3,0)
	billboard.AlwaysOnTop = true
	
	local textLabel = Instance.new("TextLabel")
	textLabel.Size = UDim2.new(1,0,1,0)
	textLabel.BackgroundTransparency = 1
	textLabel.Text = "Let's assume I am a ball (the model of the ball does not yet exist)"
	textLabel.TextColor3 = Color3.fromRGB(255,105,180) -- Rosa
	textLabel.TextScaled = true
	textLabel.Font = Enum.Font.GothamBold
	textLabel.Parent = billboard
	
	billboard.Parent = player:WaitForChild("PlayerGui")
	textBillboard = billboard
end

-- Función para reproducir sonido de activación
local function playActivateSound()
	activateSound:Stop()
	activateSound.TimePosition = 0
	activateSound:Play()
end

-- Función para reproducir sonido de desactivación
local function playDeactivateSound()
	deactivateSound:Stop()
	deactivateSound.TimePosition = 0
	deactivateSound:Play()
end

-- Función para iniciar sonido loop
local function startLoopSound()
	loopSound:Stop()
	loopSound.TimePosition = 0
	loopSound:Play()
end

-- Función para detener sonido loop
local function stopLoopSound()
	loopSound:Stop()
end

-- FOLLOW (stand a la derecha del jugador)

RunService.RenderStepped:Connect(function()

	if invisible then return end

	local right = hrp.CFrame.RightVector * 3 -- Derecha del jugador
	local up = Vector3.new(0,3,0)

	local pos = hrp.Position + right + up

	root.CFrame =
		CFrame.lookAt(pos, pos + hrp.CFrame.LookVector)

	local move = humanoid.MoveDirection:Dot(hrp.CFrame.LookVector)

	if move > 0.2 then

		if not walkFTrack.IsPlaying then
			idleTrack:Stop()
			walkFTrack:Play()
		end

	else

		if not idleTrack.IsPlaying then
			walkFTrack:Stop()
			idleTrack:Play()
		end

	end

end)

-- FUNCIÓN PARA INVISIBILIDAD/REAPARICIÓN

local function toggleInvisibility()

	if not invisible then
		-- Volverse semi-invisible
		invisible = true

		-- Reproducir sonido de activación
		playActivateSound()

		for _,track in pairs(animator:GetPlayingAnimationTracks()) do
			track:Stop()
		end

		for _,track in pairs(humanoid:GetPlayingAnimationTracks()) do
			track:Stop()
		end

		animateScript.Disabled = true

		local pos = hrp.Position + hrp.CFrame.RightVector * 6
		root.CFrame = CFrame.lookAt(pos, hrp.Position)

		root.Anchored = true
		hrp.Anchored = true

		-- Reproducir animaciones
		invisibleStandTrack:Play()
		invisiblePlayerTrack:Play()

		task.wait(invisibleStandTrack.Length)

		-- Poner transparencia 0.5 al jugador y al stand
		for _,v in pairs(standParts:GetDescendants()) do
			if v:IsA("BasePart") then
				v.Transparency = 0.5
			end
		end
		
		for _,v in pairs(char:GetDescendants()) do
			if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
				if v == head then
					v.Transparency = 1 -- Cabeza completamente invisible
				else
					v.Transparency = 0.5
				end
			end
		end
		
		sparkles.Enabled = false
		
		-- Crear texto flotante
		createText()
		
		-- Iniciar sonido en loop
		startLoopSound()

		root.Anchored = false
		hrp.Anchored = false

		animateScript.Disabled = false

		idleTrack:Play()

	else
		-- Reaparecer (volver a transparencia 0)
		
		-- Reproducir sonido de desactivación
		playDeactivateSound()

		for _,track in pairs(animator:GetPlayingAnimationTracks()) do
			track:Stop()
		end

		for _,track in pairs(humanoid:GetPlayingAnimationTracks()) do
			track:Stop()
		end

		animateScript.Disabled = true

		local pos = hrp.Position + hrp.CFrame.RightVector * 6
		root.CFrame = CFrame.lookAt(pos, hrp.Position)

		root.Anchored = true
		hrp.Anchored = true

		reappearStandTrack:Play()
		reappearPlayerTrack:Play()

		task.wait(reappearStandTrack.Length)

		-- Restaurar transparencia 0
		for _,v in pairs(standParts:GetDescendants()) do
			if v:IsA("BasePart") then
				v.Transparency = 0
			end
		end
		
		for _,v in pairs(char:GetDescendants()) do
			if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
				v.Transparency = 0
			end
		end
		
		sparkles.Enabled = true
		
		-- Detener sonido en loop
		stopLoopSound()
		
		-- Eliminar texto flotante
		if textBillboard then
			textBillboard:Destroy()
			textBillboard = nil
		end

		root.Anchored = false
		hrp.Anchored = false

		animateScript.Disabled = false

		idleTrack:Play()

		invisible = false
	end

end

UIS.InputBegan:Connect(function(input,gpe)

	if gpe then return end

	-- E - Activar/Desactivar invisibilidad
	if input.KeyCode == Enum.KeyCode.E then
		toggleInvisibility()
	end

end)

