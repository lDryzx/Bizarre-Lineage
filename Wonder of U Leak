local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()

local hrp = char:WaitForChild("HumanoidRootPart")
local humanoid = char:WaitForChild("Humanoid")

-- WONDER OF U

local standTemplate = RS.assets.models.stands["Wonder of U"]
local stand = standTemplate:Clone()
stand.Parent = workspace

local root = stand:WaitForChild("HumanoidRootPart")
local standParts = stand:WaitForChild("StandParts")

for _,v in pairs(standParts:GetDescendants()) do
	if v:IsA("BasePart") then
		v.Transparency = 0
		v.CanCollide = false
	end
end

root.Transparency = 1

-- SPARKLES OXIDADO ANARANJADO

local sparkles = Instance.new("Sparkles")
sparkles.Color = Color3.fromRGB(200,100,40)
sparkles.SparkleColor = Color3.fromRGB(200,100,40)
sparkles.Parent = root

-- ANIMATION CONTROLLER

local controller = stand:WaitForChild("AnimationController")
local animator = controller:FindFirstChildOfClass("Animator") or Instance.new("Animator",controller)

-- ANIMACIONES

local idleAnim = Instance.new("Animation")
idleAnim.AnimationId = "rbxassetid://113554966080271"
local idleTrack = animator:LoadAnimation(idleAnim)

local walkAnim = Instance.new("Animation")
walkAnim.AnimationId = "rbxassetid://98101560813883"
local walkTrack = animator:LoadAnimation(walkAnim)

local eAnim = Instance.new("Animation")
eAnim.AnimationId = "rbxassetid://91238701999322"
local eTrack = animator:LoadAnimation(eAnim)

local cAnim = Instance.new("Animation")
cAnim.AnimationId = "rbxassetid://114825194497149"
local cTrack = animator:LoadAnimation(cAnim)

local vAnim = Instance.new("Animation")
vAnim.AnimationId = "rbxassetid://113062232717397"
local vTrack = animator:LoadAnimation(vAnim)

local bAnim = Instance.new("Animation")
bAnim.AnimationId = "rbxassetid://136866895835335"
local bTrack = animator:LoadAnimation(bAnim)

idleTrack:Play()

local attacking = false

-- FOLLOW

RunService.RenderStepped:Connect(function()

	if attacking then return end

	local sideOffset = hrp.CFrame.RightVector * 2
	local pos = hrp.Position + sideOffset

	root.CFrame = CFrame.lookAt(pos, pos + hrp.CFrame.LookVector)

	local move = humanoid.MoveDirection.Magnitude

	if move > 0 then

		if not walkTrack.IsPlaying then
			idleTrack:Stop()
			walkTrack:Play()
		end

	else

		if not idleTrack.IsPlaying then
			walkTrack:Stop()
			idleTrack:Play()
		end

	end

end)

-- ATAQUE FRONTAL

local function frontAttack(track)

	attacking = true

	for _,t in pairs(animator:GetPlayingAnimationTracks()) do
		t:Stop()
	end

	local pos = hrp.Position + hrp.CFrame.LookVector * 3

	root.CFrame = CFrame.lookAt(pos, pos + hrp.CFrame.LookVector)

	root.Anchored = true

	track:Play()

	task.wait(track.Length)

	root.Anchored = false

	idleTrack:Play()

	attacking = false

end

-- INPUTS

UIS.InputBegan:Connect(function(input,gpe)

	if gpe then return end

	if input.KeyCode == Enum.KeyCode.E and not attacking then
		frontAttack(eTrack)
	end

	if input.KeyCode == Enum.KeyCode.C and not attacking then
		frontAttack(cTrack)
	end

	if input.KeyCode == Enum.KeyCode.V and not attacking then
		frontAttack(vTrack)
	end

	if input.KeyCode == Enum.KeyCode.B and not attacking then
		frontAttack(bTrack)
	end

end)

