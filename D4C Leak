-- FOLLOW
RunService.RenderStepped:Connect(function()
	if posing then return end

	local right = hrp.CFrame.RightVector * 3
	local up = Vector3.new(0,3,0)

	local pos = hrp.Position + right + up

	root.CFrame =
		CFrame.lookAt(pos, pos + hrp.CFrame.LookVector)
		* CFrame.Angles(0,math.rad(180),0)
end)

-- FUNCIÓN ATAQUE GENERICA
local function frontAttack(track)
	posing = true

	for _,t in pairs(animator:GetPlayingAnimationTracks()) do
		t:Stop()
	end

	local pos = hrp.Position + hrp.CFrame.LookVector * 5
	root.CFrame = CFrame.lookAt(pos, pos + hrp.CFrame.LookVector)

	root.Anchored = true

	track:Play()

	task.wait(track.Length)

	root.Anchored = false
	idleTrack:Play()

	posing = false
end

-- FUNCIÓN PARA CREAR CLON DEL JUGADOR
local function createPlayerClone()
	-- Eliminar clon anterior si existe
	if clone and clone.Parent then
		clone:Destroy()
		clone = nil
		cloneHumanoid = nil
		cloneAnimator = nil
	end
	
	-- Clonar al jugador (no al stand)
	clone = char:Clone()
	clone.Name = "Leak by 6QWD (D4C Clone)"
	clone.Parent = workspace
	
	-- Configurar clon
	local cloneHRP = clone:WaitForChild("HumanoidRootPart")
	cloneHumanoid = clone:WaitForChild("Humanoid")
	
	-- Posicionar clon ligeramente al frente
	cloneHRP.CFrame = hrp.CFrame * CFrame.new(0,0,-3) * CFrame.Angles(0, math.rad(180), 0)
	
	-- Desactivar scripts del clon para que no ejecute lógica duplicada
	for _,v in pairs(clone:GetDescendants()) do
		if v:IsA("Script") or v:IsA("LocalScript") then
			v.Disabled = true
		end
	end
	
	-- Desactivar el script de animaciones del clon
	local cloneAnimate = clone:FindFirstChild("Animate")
	if cloneAnimate then
		cloneAnimate.Disabled = true
	end
	
	-- Hacer el clon semitransparente (efecto visual)
	for _,v in pairs(clone:GetDescendants()) do
		if v:IsA("BasePart") and v ~= cloneHRP then
			v.Transparency = 0.5
		end
	end
	
	-- Obtener o crear Animator para el clon
	cloneAnimator = cloneHumanoid:FindFirstChildOfClass("Animator")
	if not cloneAnimator then
		cloneAnimator = Instance.new("Animator", cloneHumanoid)
	end
	
	print("Clon creado:", clone.Name)
end

-- FUNCIÓN PARA QUE EL CLON DISPARE
local function cloneShoot()
	if clone and cloneHumanoid and cloneAnimator then
		-- Cargar y reproducir animación de disparo en el clon
		local shootTrack = cloneAnimator:LoadAnimation(cloneShootAnim)
		shootTrack:Play()
		
		-- Buscar revolver en el clon (si existe)
		local cloneRevolver = clone:FindFirstChild("Revolver", true)
		if cloneRevolver then
			cloneRevolver.Transparency = 0
		end
		
		-- Esperar duración de la animación
		task.wait(shootTrack.Length)
		
		-- Ocultar revolver del clon
		if cloneRevolver then
			cloneRevolver.Transparency = 1
		end
		
		shootTrack:Destroy()
	else
		warn("No hay clon disponible para disparar")
	end
end

-- INPUT HANDLER
UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end

	-- B - Crear clon del jugador
	if input.KeyCode == Enum.KeyCode.B and not posing then
		posing = true

		-- Detener animaciones actuales
		for _,track in pairs(humanoid:GetPlayingAnimationTracks()) do
			track:Stop()
		end

		-- Reproducir animación de creación de clon
		cloneTrack:Play()
		
		-- Crear el clon después de un pequeño delay (sincronizado con la animación)
		task.wait(0.5) -- Ajusta este tiempo según la animación
		createPlayerClone()
		
		-- Esperar a que termine la animación
		task.wait(cloneTrack.Length - 0.5)
		cloneTrack:Stop()
		
		posing = false
		idleTrack:Play()
	end

	-- E - Si hay clon, que dispare; si no, ataque del stand
	if input.KeyCode == Enum.KeyCode.E and not posing then
		if clone and clone.Parent and cloneHumanoid then
			-- Hay clon, que dispare
			cloneShoot()
		else
			-- No hay clon, ataque normal del stand
			frontAttack(hitTrack)
		end
	end

	-- C - Animación con bandera
	if input.KeyCode == Enum.KeyCode.C and not posing then
		if not flagActive then
			flagActive = true
			
			-- Mostrar bandera
			if flag then flag.Transparency = 0 end
			
			flagPlayerTrack:Play()
			
			task.wait(flagPlayerTrack.Length)
			
			flagPlayerTrack:Stop()
			
			-- Ocultar bandera
			if flag then flag.Transparency = 1 end
			flagActive = false
		end
	end

	-- V - Animación con revolver
	if input.KeyCode == Enum.KeyCode.V and not posing then
		if not revolverActive then
			revolverActive = true
			
			-- Mostrar revolver
			if revolver then 
				revolver.Transparency = 0
			end
			
			revolverPlayerTrack:Play()
			
			task.wait(revolverPlayerTrack.Length)
			
			revolverPlayerTrack:Stop()
			
			-- Ocultar revolver
			if revolver then revolver.Transparency = 1 end
			revolverActive = false
		end
	end

	-- L - Animación sincronizada (stand y jugador)
	if input.KeyCode == Enum.KeyCode.L and not posing then
		posing = true

		for _,track in pairs(animator:GetPlayingAnimationTracks()) do
			track:Stop()
		end

		for _,track in pairs(humanoid:GetPlayingAnimationTracks()) do
			track:Stop()
		end

		animateScript.Disabled = true

		local pos = hrp.Position + hrp.CFrame.LookVector * 6
		root.CFrame = CFrame.lookAt(pos, hrp.Position)

		root.Anchored = true
		hrp.Anchored = true

		lStandTrack:Play()
		lPlayerTrack:Play()

		task.wait(lStandTrack.Length)

		humanoid:TakeDamage(37)

		root.Anchored = false
		hrp.Anchored = false

		animateScript.Disabled = false

		idleTrack:Play()
		posing = false
	end
end)

