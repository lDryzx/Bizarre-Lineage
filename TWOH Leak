-- FOLLOW

RunService.RenderStepped:Connect(function()

	if posing or pActive then return end

	local right = hrp.CFrame.RightVector * 3
	local up = Vector3.new(0,3,0)

	local pos = hrp.Position + right + up

	root.CFrame =
		CFrame.lookAt(pos, pos + hrp.CFrame.LookVector)
		* CFrame.Angles(0,math.rad(180),0)

	local move = humanoid.MoveDirection:Dot(hrp.CFrame.LookVector)

	if move > 0.2 then

		if not walkFTrack.IsPlaying then
			idleTrack:Stop()
			walkBTrack:Stop()
			walkFTrack:Play()
		end

	elseif move < -0.2 then

		if not walkBTrack.IsPlaying then
			idleTrack:Stop()
			walkFTrack:Stop()
			walkBTrack:Play()
		end

	else

		if not idleTrack.IsPlaying then
			walkFTrack:Stop()
			walkBTrack:Stop()
			idleTrack:Play()
		end

	end

end)

-- FUNCION ATAQUE FRONTAL

local function frontAttack(track)

	posing = true

	for _,t in pairs(animator:GetPlayingAnimationTracks()) do
		t:Stop()
	end

	local pos = hrp.Position + hrp.CFrame.LookVector * 5
	root.CFrame = CFrame.lookAt(pos, pos + hrp.CFrame.LookVector)

	root.Anchored = true

	track:Play()

	task.wait(track.Length)

	root.Anchored = false
	idleTrack:Play()

	posing = false

end

UIS.InputBegan:Connect(function(input,gpe)

	if gpe then return end

	-- E
	if input.KeyCode == Enum.KeyCode.E and not posing then
		frontAttack(eTrack)
	end

	-- C
	if input.KeyCode == Enum.KeyCode.C and not posing then
		frontAttack(cTrack)
	end

	-- V
	if input.KeyCode == Enum.KeyCode.V and not posing then
		frontAttack(vTrack)
	end

	-- B
	if input.KeyCode == Enum.KeyCode.B and not posing then
		frontAttack(bTrack)
	end

	-- P

	if input.KeyCode == Enum.KeyCode.P then

		if not pActive then

			pActive = true

			for _,track in pairs(animator:GetPlayingAnimationTracks()) do
				track:Stop()
			end

			idleTrack:Stop()

			local pos =
				hrp.Position
				- hrp.CFrame.LookVector * 2
				+ Vector3.new(0,3,0)

			root.CFrame = CFrame.lookAt(pos, hrp.Position)

			pTrack:Play()
			pPlayerTrack:Play()

		else

			pActive = false

			pTrack:Stop()
			pPlayerTrack:Stop()

			idleTrack:Play()

		end

	end

	-- L

	if input.KeyCode == Enum.KeyCode.L and not posing then

		posing = true

		for _,track in pairs(animator:GetPlayingAnimationTracks()) do
			track:Stop()
		end

		for _,track in pairs(humanoid:GetPlayingAnimationTracks()) do
			track:Stop()
		end

		animateScript.Disabled = true

		local pos = hrp.Position + hrp.CFrame.LookVector * 6
		root.CFrame = CFrame.lookAt(pos, hrp.Position)

		root.Anchored = true
		hrp.Anchored = true

		lStandTrack:Play()
		lPlayerTrack:Play()

		task.wait(lStandTrack.Length)

		humanoid:TakeDamage(37)

		root.Anchored = false
		hrp.Anchored = false

		animateScript.Disabled = false

		idleTrack:Play()

		posing = false

	end

	-- X (solo jugador)

	if input.KeyCode == Enum.KeyCode.X then
		xTrack:Play()
	end

end)

